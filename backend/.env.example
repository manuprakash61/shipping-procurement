# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shipping_procurement

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_me_32_char_random_hex_string_here
JWT_REFRESH_SECRET=change_me_another_32_char_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (for API keys stored in DB)
ENCRYPTION_KEY=change_me_32_char_hex_for_aes_256

# AI
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Search
SERPAPI_KEY=your_serpapi_key_here
BRAVE_SEARCH_API_KEY=your_brave_search_key_here

# Email (Gmail)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
FROM_NAME=ShipProcure

# Google Places
GOOGLE_PLACES_API_KEY=your_google_places_key

# Email Verification (optional)
HUNTER_API_KEY=your_hunter_io_key

# AWS S3 (for tender PDF storage)
AWS_S3_BUCKET=shipping-procurement-docs
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
